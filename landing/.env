# Local-only environment overrides for Arcane Identity landing page.
# This file is gitignored (see .gitignore → .env*.local).
# Next.js exposes any NEXT_PUBLIC_* var to the browser; keep secrets out of those.

# Canonical origin used for metadata, OG tags, sitemap.
# Replace the hardcoded URL in app/layout.tsx → metadataBase with process.env.NEXT_PUBLIC_SITE_URL
# once you wire it up.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics (uncomment + fill if you add one later):
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=arcane.id
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Waitlist / access form endpoint. Used by components/access-modal.tsx.
# Expected format: a JSON-accepting POST URL, e.g. https://formspree.io/f/xxxxxxxx
# When unset, the modal falls back to opening the user's mail client.
NEXT_PUBLIC_ACCESS_FORM_ENDPOINT=https://formspree.io/f/xpqkldjy

# Embeddable booking URL shown on the modal's success step.
# Expected format: https://cal.com/<user>/<event>?embed=true (or any embeddable scheduler).
# When unset, the success step shows the confirmation copy without a calendar.
NEXT_PUBLIC_BOOKING_URL=https://calendly.com/danyal-arcaneidentity/arcane-identity-kickoff

# Email where "Book a briefing" mailto: link points, if you decide to make it
# configurable instead of the current hardcoded value.
# NEXT_PUBLIC_CONTACT_EMAIL=access@arcane.id
